def attention_rollout(model, img_tensor):
    """
    Attention Rollout across all transformer layers.
    Temporarily patches the attention forward pass to bypass Flash Attention,
    keeping computations on the GPU for optimal time and space complexity.
    """
    model.eval()
    attn_weights_list = []
    original_forwards = {}

    def get_patched_forward(module):
        # Added **kwargs to catch 'attn_mask' and 'is_causal' 
        def patched_forward(x, **kwargs):
            B, N, C = x.shape
            # Standard timm ViT qkv projection
            qkv = module.qkv(x).reshape(B, N, 3, module.num_heads, module.head_dim).permute(2, 0, 3, 1, 4)
            q, k, v = qkv.unbind(0)

            # Manual attention calculation
            q = q * module.scale
            attn = (q @ k.transpose(-2, -1))
            attn = attn.softmax(dim=-1)

            # Capture weights (detached, kept on GPU)
            attn_weights_list.append(attn.detach())

            attn = module.attn_drop(attn)
            x = (attn @ v).transpose(1, 2).reshape(B, N, C)
            x = module.proj(x)
            x = module.proj_drop(x)
            return x
        return patched_forward

    # 1. Apply temporary patches to intercept the weights
    for i, block in enumerate(model.blocks):
        original_forwards[i] = block.attn.forward
        block.attn.forward = get_patched_forward(block.attn)

    # 2. Run inference
    with torch.no_grad():
        _ = model(img_tensor)

    # 3. Clean up: Restore original model structure immediately
    for i, block in enumerate(model.blocks):
        block.attn.forward = original_forwards[i]

    if not attn_weights_list:
        print("⚠️ Fallback attention")
        return np.ones((14, 14))

    # 4. Rollout computation (GPU Accelerated)
    device = img_tensor.device
    result = torch.eye(attn_weights_list[0].shape[-1], device=device)
    
    for attn in attn_weights_list:
        attn_avg = attn.mean(dim=1).squeeze(0)
        attn_aug = attn_avg + torch.eye(attn_avg.shape[0], device=device)
        attn_aug = attn_aug / attn_aug.sum(dim=-1, keepdim=True)
        result   = torch.matmul(attn_aug, result)

    # Extract class token attention to all other patches
    mask = result[0, 1:]
    h = w = int(mask.shape[0] ** 0.5)
    
    # 5. Move final small mask to CPU for rendering
    mask = mask.reshape(h, w).cpu().numpy()
    mask = (mask - mask.min()) / (mask.max() - mask.min() + 1e-8)
    return mask

