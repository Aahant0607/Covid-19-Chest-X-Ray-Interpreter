# ── ENSEMBLE WRAPPER ──────────────────────────────────────────
# Wraps CNN + ViT into a single callable model
# Used for all explainability methods
class EnsembleModel(nn.Module):
    def __init__(self, cnn, vit, cnn_weight=0.5):
        super().__init__()
        self.cnn        = cnn
        self.vit        = vit
        self.cnn_weight = cnn_weight

    def forward(self, x):
        cnn_probs = torch.softmax(self.cnn(x), dim=1)
        vit_probs = torch.softmax(self.vit(x), dim=1)
        return self.cnn_weight * cnn_probs + (1 - self.cnn_weight) * vit_probs

