# Helper: tensor → numpy for visualization
def tensor_to_np(t):
    """Denormalize and convert tensor to HWC numpy array"""
    t   = t.squeeze(0).cpu()
    inv = transforms.Normalize(
        mean=[-m/s for m, s in zip(MEAN, STD)],
        std=[1/s for s in STD]
    )
    t = inv(t).clamp(0, 1)
    return t.permute(1, 2, 0).numpy()

