    attrs    = ig.attribute(img_t, baseline, target=lbl, n_steps=50)
    attrs_np = attrs.squeeze(0).cpu().detach().numpy()
    attrs_np = np.mean(np.abs(attrs_np), axis=0)
    attrs_np = (attrs_np - attrs_np.min()) / (attrs_np.max() - attrs_np.min() + 1e-8)
    ig_maps.append(attrs_np)

