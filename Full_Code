# Helper: unwrap DataParallel for inference
def unwrap(model):
    return model.module if isinstance(model, nn.DataParallel) else model

# ── EVALUATE FUNCTION ─────────────────────────────────────────
def evaluate(model, loader, model_name):
    m = unwrap(model)
    m.eval()
    all_preds, all_labels = [], []
    with torch.no_grad():
        for imgs, labels in loader:
            imgs  = imgs.to(device)
            preds = m(imgs).argmax(1).cpu()
            all_preds.extend(preds.numpy())
            all_labels.extend(labels.numpy())

    print(f"\n{'='*55}")
    print(f"  {model_name} — Test Set Results")
    print(f"{'='*55}")
    print(classification_report(all_labels, all_preds, target_names=CLASSES))

    cm = confusion_matrix(all_labels, all_preds)
    plt.figure(figsize=(7, 5))
    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
                xticklabels=CLASSES, yticklabels=CLASSES)
    plt.title(f"{model_name} — Confusion Matrix")
    plt.ylabel("True Label")
    plt.xlabel("Predicted Label")
    plt.tight_layout()
    plt.savefig(f"{SAVE_DIR}/{model_name}_confusion.png", dpi=150)
    plt.show()
    return all_preds, all_labels

# ── TTA FUNCTION ──────────────────────────────────────────────
def predict_with_tta(model, loader, model_name, n_augments=10):
    m = unwrap(model)
    m.eval()
    all_probs, all_labels = [], []
    with torch.no_grad():
        for imgs, labels in loader:
            imgs        = imgs.to(device)
            batch_probs = torch.zeros(imgs.size(0), NUM_CLASSES).to(device)
            for _ in range(n_augments):
                batch_probs += torch.softmax(m(imgs), dim=1)
            batch_probs /= n_augments
            all_probs.append(batch_probs.cpu())
            all_labels.extend(labels.numpy())

    all_probs  = torch.cat(all_probs)
    all_preds  = all_probs.argmax(1).numpy()
    all_labels = np.array(all_labels)

    print(f"\n{'='*55}")
    print(f"  {model_name} + TTA — Test Set Results")
    print(f"{'='*55}")
    print(classification_report(all_labels, all_preds, target_names=CLASSES))

    cm = confusion_matrix(all_labels, all_preds)
    plt.figure(figsize=(7, 5))
    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
                xticklabels=CLASSES, yticklabels=CLASSES)
    plt.title(f"{model_name} + TTA — Confusion Matrix")
    plt.ylabel("True Label")
    plt.xlabel("Predicted Label")
    plt.tight_layout()
    plt.savefig(f"{SAVE_DIR}/{model_name}_TTA_confusion.png", dpi=150)
    plt.show()
    return all_preds, all_labels.tolist()

# ── ENSEMBLE FUNCTION ─────────────────────────────────────────
def ensemble_predict(cnn_model, vit_model, loader, cnn_weight=0.5):
    cnn_m = unwrap(cnn_model)
    vit_m = unwrap(vit_model)
    cnn_m.eval()
    vit_m.eval()
    all_preds, all_labels = [], []
    with torch.no_grad():
        for imgs, labels in loader:
            imgs      = imgs.to(device)
            cnn_probs = torch.softmax(cnn_m(imgs), dim=1)
            vit_probs = torch.softmax(vit_m(imgs), dim=1)
            combined  = cnn_weight * cnn_probs + (1 - cnn_weight) * vit_probs
            all_preds.extend(combined.argmax(1).cpu().numpy())
            all_labels.extend(labels.numpy())

    print(f"\n{'='*55}")
    print(f"  Ensemble (B4 + ViT) — Test Set Results")
    print(f"{'='*55}")
    print(classification_report(all_labels, all_preds, target_names=CLASSES))

    cm = confusion_matrix(all_labels, all_preds)
    plt.figure(figsize=(7, 5))
    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
                xticklabels=CLASSES, yticklabels=CLASSES)
    plt.title("Ensemble (B4 + ViT) — Confusion Matrix")
    plt.ylabel("True Label")
    plt.xlabel("Predicted Label")
    plt.tight_layout()
    plt.savefig(f"{SAVE_DIR}/Ensemble_confusion.png", dpi=150)
    plt.show()
    return all_preds, all_labels

