def get_test_samples(n_per_class=3):
    """
    Returns raw PIL images + tensors + labels
    for n_per_class samples from each class
    """
    raw_imgs, tensors, labels, paths = [], [], [], []
    for cls_idx, cls_name in enumerate(CLASSES):
        cls_path  = os.path.join(TEST_PATH, cls_name)
        img_files = os.listdir(cls_path)[:n_per_class]
        for fname in img_files:
            full_path = os.path.join(cls_path, fname)
            img_pil   = Image.open(full_path).convert('RGB')
            img_t     = val_test_transforms(img_pil).unsqueeze(0).to(device)
            raw_imgs.append(img_pil)
            tensors.append(img_t)
            labels.append(cls_idx)
            paths.append(full_path)
    print(f"Loaded {len(raw_imgs)} images "
          f"({n_per_class} per class × {len(CLASSES)} classes)")
    return raw_imgs, tensors, labels, paths

